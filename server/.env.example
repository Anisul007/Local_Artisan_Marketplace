# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# MongoDB connection (required)
# Local:   mongodb://127.0.0.1:27017/artisan-avenue
# Atlas:   mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/artisan-avenue?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/artisan-avenue

# JWT secret for auth cookies (required) — use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: reset flow can use a separate secret
# RESET_JWT_SECRET=another-secret-for-password-reset

# Optional: server port (default 4000)
# PORT=4000

# Optional: email (SMTP) for verification / password reset
# Mailtrap: Email Testing → your inbox → SMTP Settings. Emails appear in Mailtrap INBOX, not Gmail.
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your-mailtrap-username
# SMTP_PASS=your-mailtrap-password
# SMTP_FROM=Artisan Avenue <no-reply@artisan-avenue.local>
