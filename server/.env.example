# Copy to server/.env (SETUP.bat / npm run setup does this automatically)

NODE_ENV=development
PORT=4000

# Required — change in production
JWT_SECRET=dev-change-me-artisan-avenue-local-only
MONGO_URI=mongodb://127.0.0.1:27017/artisan_avenue

# Optional: comma-separated origins for production CORS (e.g. https://yourdomain.com)
# CORS_ORIGIN=

# --- Demo admin (used by npm run seed) ---
ADMIN_EMAIL=admin@artisan.test
ADMIN_PASSWORD=AdminPass123!
ADMIN_USERNAME=admin
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin

# --- Email ---
# Leave SMTP blank for local dev: emails are saved to .mail-previews/ instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Artisan Avenue <noreply@example.com>

# Mailtrap example: host sandbox.smtp.mailtrap.io, port 2525
# MAIL_MIN_SEND_INTERVAL_MS=1200

# Save outbound emails as files when SMTP is not configured (recommended for first run)
MAIL_PREVIEW_DIR=.mail-previews

# Same variables also work as MAIL_HOST, MAIL_PORT, MAIL_USER, MAIL_PASS, MAIL_FROM
