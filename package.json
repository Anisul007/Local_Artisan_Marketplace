{
  "name": "artisan-avenue",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "seed": "npm run seed:all --prefix server",
    "dev": "npm run dev:client",
    "dev:client": "vite --port 5173",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently -n web,api -c green,blue \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "start:prod": "npm run build && cross-env NODE_ENV=production npm run start --prefix server"
  },
  "dependencies": {
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.542.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.0",
    "vite": "^7.1.3"
  },
  "engines": {
    "node": ">=18 <=22",
    "npm": ">=9"
  }
}
